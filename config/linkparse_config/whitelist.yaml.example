# ==============================================================
# LinkFlow-Plugin 链接解析群白名单
# ==============================================================
# enabled : 是否启用白名单（false=不限制，所有群可用；true=仅名单内群可解析下载）
# groups  : 允许解析/下载的群号列表，通过 #开启解析 / #关闭解析 管理
#
# 注意：
#   - enabled=false 时所有群均可解析，#开启解析 仍会将群加入列表（待启用后生效）
#   - enabled=true 时仅列表中的群可解析，不在列表中的群发送链接被忽略
# ==============================================================

enabled: false
groups: []
