# ==============================================================
# Bilibili-Plugin 配置文件
# 请将此文件复制为 config.yaml 并根据需要修改
# ==============================================================

# B站账号登录（apps/login.js）
login:
  # 扫码登录轮询超时（秒）
  pollTimeout: 180

# B站激励计划（apps/incentive.js）
incentive:
  # ---------- 全局开关 ----------
  enabled: true
  # ---------- 主领取 cron ----------
  claimCron: '0 0 1 * * ?'
  # ---------- 看播领取 cron ----------
  watchCron: '0 30 0 * * ?'
  # ---------- 兜底领取 cron ----------
  fallbackCron: '0 55 23 * * ?'
  # ---------- 全局截止时间（秒），0=不限 ----------
  claimDeadline: 40
  # ---------- 领取设置 ----------
  claim:
    # 并发领取线程数（同时发送请求的 worker 数量，建议 2-5）
    threadCount: 2
    # 单个 worker 最大重试次数
    maxRetry: 30
    # 重试间隔（秒）
    retryInterval: 1.0
    # 单次请求超时（秒）
    timeout: 10
  # ---------- 每日兜底任务（4个，主人配置）----------
  dailyTaskLinks:
    - ''
    - ''
    - ''
    - ''
